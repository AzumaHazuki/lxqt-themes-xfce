# Xfce-4.4 Openbox theme
# By Azuma Hazuki (wanderinghazuki@gmail.com)
# Created on 14 Feb. 2023

# Globals

*.padding.width:			3
*.padding.height:			3

*.border.color:				#424340
*.border.width:				1

*.justify:				center
*.text.color:				#000000

# Window settings

window.handle.width:			4

window.client.padding.width:		3
window.client.padding.height:		0

window.active.title.bg:			raised gradient vertical
window.active.title.bg.color:		#81827e
window.active.title.bg.colorTo:		#9c9e9a
window.active.title.separator.color:	#81827e

window.active.title.padding.width:	1
window.active.title.padding.height:	1

window.active.label.bg:			parentrelative
window.active.label.text.color:		#ffffff
window.active.label.text.font:		shadow=y:shadowtint=60:shadowoffset=1

window.active.handle.bg:		flat solid
window.active.handle.bg.color:		#eeeeec

window.active.grip.bg:			flat solid
window.active.grip.bg.color:		#eeeeec

window.active.client.color:		#eeeeec

window.inactive.title.bg:		flat solid
window.inactive.title.bg.color:		#eeeeec

window.inactive.label.bg:		parentrelative
window.inactive.label.text.color:	#888a85

window.inactive.handle.bg:		flat solid
window.inactive.handle.bg.color:	#eeeeec

window.inactive.grip.bg:		flat solid
window.inactive.grip.bg.color:		#eeeeec

window.inactive.client.color:		#eeeeec

# Window button settings

window.active.button.*.bg:		parentrelative
window.active.button.*.image.color:	#ffffff

window.inactive.button.*.bg:		parentrelative
window.inactive.button.*.image.color:	#888a85

# Menu settings

menu.border.width:			1
menu.border.color:			#81827e

menu.title.bg:				raised gradient vertical
menu.title.bg.color:			#81827e
menu.title.bg.colorTo:			#9c9e9a
menu.title.text.color:			#ffffff
menu.title.text.font:			shadow=y:shadowtint=60:shadowoffset=1

menu.items.bg:				flat solid
menu.items.bg.color:			#ffffff
menu.items.justify:			left

menu.items.active.bg:			flat solid
menu.items.active.bg.color:		#3465a4
menu.items.active.text.color:		#ffffff

menu.items.disabled.text.color:		#888a85
menu.items.active.disabled.text.color:	#ffffff

# OSD/Switcher Settings

osd.hilight.bg:				raised gradient vertical
osd.hilight.bg.color:			#f7f7f6
osd.hilight.bg.colorTo:			#eeeeec

osd.unhilight.bg:			flat solid
osd.unhilight.bg.color:			#edebe9
