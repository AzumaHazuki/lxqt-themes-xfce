/* The main Leave dialog window */
QDialog {
	color:				#000000;
	background:			#aeb2c3;

	border:				2px solid transparent;
	border-image:			url(assets/scrollbars/handle.png) 2;
}

/* Caption colors */
QLabel {
	color:				#000000;
	background:			transparent;

	padding:			8px;
}

/* Available actions - only partially themeable as of LXQt 1.2.x */
QAbstractItemView {
	color:				#000000;
	background:			#fcfcf0; /* This doesn't work for some reason... */
	background-image:		url(assets/menus/bg.png); /* ...but this does! */

	border:				1px solid #74798e;
}

/* Button settings */
QPushButton {
        color:                          #000000;
        background:                     #aeb2c3;

        border:                         2px solid transparent;
        border-image:                   url(assets/buttons/button.png) 2;

        padding-left:                   24px;
        padding-right:                  24px;
        padding-top:                    4px;
        padding-bottom:			4px;

	margin-left:			10px;
	margin-right:			10px;
}

QToolButton {
        color:                          #000000;
        background:                     #aeb2c3;

        border:                         2px solid transparent;
        border-image:                   url(assets/buttons/button.png) 2;

        padding-left:                   6px;
        padding-right:                  6px;
        padding-top:                    4px;
        padding-bottom:			4px;

	margin-left:			10px;
	margin-right:			10px;
}

QPushButton:hover, QToolButton:hover {
        background:                     #aeb2c3;
        border-image:                   url(assets/buttons/hover.png) 2;}

QPushButton:pressed, QToolButton:pressed {
        background:                     #9ba0b0;
        border-image:                   url(assets/buttons/active.png) 2;
}
