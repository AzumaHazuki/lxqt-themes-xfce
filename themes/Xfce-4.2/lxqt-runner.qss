/* Panel */
#panel {
	color:				#000000;
	background:			#edeff2;

	border:				1px solid #b3b3b3;
}

/* Buttons */
QToolButton::menu-indicator {
	image:				none;
}

#closeButton {
	border:				1px solid transparent;
	background:			#edeff2;

	qproperty-icon:			url(lxqt-runner/close.svg);
	margin:				2px;

	padding:			4px;
}

#actionButton {
	border:				1px solid transparent;
	background:			#edeff2;

	qproperty-icon:			url(lxqt-runner/down-arrow.svg);
	margin:				2px;

	padding:			4px;
}

#closeButton:hover, #actionButton:hover {
        color:                          #000000;
        background:                     qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #fdfdfe, stop:1 #e5e8ef);

        border:                         2px solid transparent;
        border-image:                   url(hover.png) 2;
}

#closeButton:pressed, #actionButton:pressed {
        color:                          #000000;
        background:                     qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #e5e8ef, stop:1 #fdfdfe);

        border:                         2px solid transparent;
        border-image:                   url(active.png) 2;
}

/* Command Box */
#commandEd {
        color:                          #000000;
        background:                     #ffffff;

        selection-color:                #ffffff;
        selection-background-color:     #5582c2;

        padding:                        2px;

        margin:                         2px;

        border:                         1px solid #b3b3b3;
        border-radius:                  2px;
}

/* Search results list */
#commandList {
	background:			#ffffff;
	color:				#000000;

	selection-color:		#ffffff;
	selection-background-color:	#5582c2;

	alternate-background-color:	#ffffff;

	border:				none;
}

#commandList::item, #commandList::item:alternate {
	color:				#000000;
	background:			#ffffff;

	margin:				1px;
}

#commandList::item:hover, #commandList::item:selected {
        color:                          #ffffff;
	background:			#5582c2;

	border:				1px solid #415c82;

	margin:				1px;
}

/* Menus */
QMenu {
        color:                          #000000;
        background:                     #ffffff;

        border:                         1px solid #b3b3b3;

        min-width:                      100px;
}

QMenu::icon {
        color:                          #000000;
        background:                     transparent;

        padding-left:                   3px;
}

QMenu::item
{
        color:                          #000000;
        background:                     #ffffff;

        border:                         1px solid transparent;

        padding-left:                   6px;
        padding-right:                  12px;
        padding-top:                    1px;
        padding-bottom:                 1px;
}

QMenu::item:selected
{
        color:                          #000000;
        background:                     qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #fdfdfe, stop:1 #e5e8ef);

        border:                         1px solid #949b8d;
}

QMenu::item:disabled {
        color:                          #8e8e8a;
        background:                     #ffffff;
}

QMenu::indicator {
        width:                          14px;
        height:                         14px;
        background:                     transparent;
        padding-left:                   5px;
}

QMenu::item:disabled {
	color:				#8e8e8a;
	background:			transparent;
}
